\setbeamertemplate{footline}{
	\leavevmode%
	\hbox{%
		% --- Parte izquierda ---
		\begin{beamercolorbox}[wd=.3\paperwidth,ht=2.5ex,dp=1.5ex,left]{footline left}
			\usebeamerfont{footline left}\hspace{1em}\footleft
		\end{beamercolorbox}%
		% --- Parte central ---
		\begin{beamercolorbox}[wd=.4\paperwidth,ht=2.5ex,dp=1.5ex,center]{footline center}
			\usebeamerfont{footline center}\footcenter
		\end{beamercolorbox}%
		% --- Parte derecha ---
		\begin{beamercolorbox}[wd=.3\paperwidth,ht=2.5ex,dp=1.5ex,right]{footline right}
			\usebeamerfont{footline right}\footright\hspace{1em}
		\end{beamercolorbox}%
	}
	\vskip0pt%
}

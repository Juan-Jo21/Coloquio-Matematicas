% ======================= Cinfiguración del título =======================
\makeatletter
\setbeamertemplate{title page}
{
	\ifdefined\datename \date{\datename} \else \date{\today} \fi
	
	\vbox{}
	\vfill
	\begingroup
	\centering
	{\scshape\scriptsize \course}\vskip0.5em
	
	% --- Título con Fuente --- Aquí el --- \fontsize{tamaño de la letra}{tamaño del espacio entre lineas} ---
	\begin{beamercolorbox}[sep=4pt,center]{title}
	{\lato\Large\fontsize{16}{16}\selectfont
		\color{white}
		\inserttitle\par}
		\ifx\insertsubtitle\@empty%
		\else%
		\vskip0.1em%
		{\usebeamerfont{subtitle}\normalsize\insertsubtitle\par}%
		\fi%     
	\end{beamercolorbox}%
	
%	% --- Título sin Fuente ---
%	\begin{beamercolorbox}[sep=4pt,center]{title}
%		\usebeamerfont{title}\LARGE\inserttitle\par%
%		\ifx\insertsubtitle\@empty%
%		\else%
%		\vskip0.1em%
%		{\usebeamerfont{subtitle}\normalsize\insertsubtitle\par}%
%		\fi%     
%	\end{beamercolorbox}%
	
	\vspace{0.1cm}
	
	\vskip0.5em\par
	
	% --- Autor ---
	\begin{beamercolorbox}[sep=0.0mm,center]{author}
		\usebeamerfont{author}\insertauthor\\
		{}
	\end{beamercolorbox}%
	
	\vspace{0.1cm}
	
	% --- UAGro ---
	\vspace{0.2cm}
	\begin{beamercolorbox}[sep=0.0mm,center]{institute}
		\vspace{0.2cm}
		\noindent
		{\color{mainblue}\rule{0.36\linewidth}{0.5pt}} %Linea izquierda
		\hspace{0.1cm}
		{\scriptsize\bfseries\deedegree}
		\hspace{0.1cm}
		{\color{mainblue}\rule{0.36\linewidth}{0.5pt}} %Linea derecha
		\par\vspace{0.1cm}
		\usebeamerfont{institute}\insertinstitute
	\end{beamercolorbox}
	
	\vskip0.5em
	%4.6
	% --- Logos ---
	\begin{tabularx}{1\textwidth}{ X <{\centering\arraybackslash}m{6cm} X >{\centering\arraybackslash}m{1.2cm} X}
		~ & \includegraphics[width=2cm,keepaspectratio]{Uagro} & ~~ & \includegraphics[width=2cm,keepaspectratio]{MMA-LOGO} & ~\\
	\end{tabularx}\\
	
	\endgroup
	\vfill
}
